---
layout: base.njk
---
{#
  Home. A reverse-chronological list of posts — this is a blog, not an ordered
  guide, so no numbering and no "spine". A `featured: true` post is lifted out
  and rendered large at the top; everything else follows newest-first.

  Intro and feed share one container (.wrap article), so they line up on the
  same left edge and reading measure. Each entry leads with its title; the
  topics and date sit together on a quiet meta line beneath it.
#}
{% macro entry(post, big=false) %}
<article class="entry">
  {% if big %}
  <h1 class="entry__title"><a href="{{ post.url }}">{{ post.data.title }}</a></h1>
  {%- else %}
  <h2 class="entry__title"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
  {%- endif %}
  {%- if post.data.dek %}
  <p class="lead">{{ post.data.dek }}</p>
  {%- endif %}
  <p class="byline mono">
    {{ post.date | readableDate }}
    {%- if post.data.topics.length %} · {{ post.data.topics | join(" · ") }}{% endif %}
  </p>
</article>
{% endmacro %}

<div class="wrap article">
  <header class="masthead">
    <p class="eyebrow">Photographs &amp; field notes</p>
    <p class="hero__thesis">{{ site.description }}</p>
  </header>

  <hr>

  {%- for post in collections.featured %}
  {{ entry(post, true) }}
  {%- endfor %}

  {%- for post in collections.posts %}
  {%- if not post.data.featured %}
  {{ entry(post) }}
  {%- endif %}
  {%- else %}
  {%- if not collections.featured.length %}
  <p class="lead">No posts yet.</p>
  {%- endif %}
  {%- endfor %}
</div>
