---
layout: base.njk
---
{#
  Home. A reverse-chronological list of posts — this is a blog, not an ordered
  guide, so no numbering and no "spine". A `featured: true` post is lifted out
  and rendered large at the top; everything else follows newest-first.

  The feed is built from typographic primitives (.eyebrow, .lead, .byline)
  rather than a dedicated card component: restraint is the design.
#}
{% macro entry(post, big=false) %}
<article class="entry{{ ' entry--featured' if big }}">
  {%- if post.data.topics.length %}
  <p class="eyebrow">{{ post.data.topics | join(" · ") }}</p>
  {%- endif %}
  {% if big %}<h1><a href="{{ post.url }}">{{ post.data.title }}</a></h1>
  {%- else %}<h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>{% endif %}
  {%- if post.data.dek %}
  <p class="lead">{{ post.data.dek }}</p>
  {%- endif %}
  <p class="byline mono">{{ post.date | readableDate }}</p>
</article>
{% endmacro %}

<section class="hero">
  <p class="eyebrow">Photographs &amp; field notes</p>
  <p class="hero__thesis">{{ site.description }}</p>
</section>

<div class="wrap">
  {%- for post in collections.featured %}
  {{ entry(post, true) }}
  {%- endfor %}

  {%- for post in collections.posts %}
  {%- if not post.data.featured %}
  {{ entry(post) }}
  {%- endif %}
  {%- else %}
  {%- if not collections.featured.length %}
  <p class="lead">No posts yet.</p>
  {%- endif %}
  {%- endfor %}
</div>
