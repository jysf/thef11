#!/usr/bin/env bash
#
# .githooks/pre-commit
#
# A thin wrapper. All the logic lives in scripts/audit-images.sh so that this
# hook and the CI audit job run IDENTICAL code and cannot drift apart.
#
# This hook is fast local feedback. It is NOT the enforcement boundary:
#   - it can be bypassed with `git commit --no-verify`
#   - it does not exist on a fresh clone until hooks are installed
# CI is the real enforcement. Both call the same script.
#
# Installed by `npm run prepare` (which sets core.hooksPath to .githooks),
# so it is versioned and shared, unlike .git/hooks/.

set -euo pipefail

# scripts/audit-images.sh needs Bash >= 4 (associative arrays), but macOS ships
# Bash 3.2 as /bin/bash and `#!/usr/bin/env bash` can resolve to it depending on
# PATH order. Prefer a Homebrew bash if present, else whatever `bash` resolves to
# (Bash 5 on Linux/CI). On macOS, `brew install bash` provides one.
run_bash="$(command -v /opt/homebrew/bin/bash \
  || command -v /usr/local/bin/bash \
  || command -v bash)"

exec "$run_bash" "$(git rev-parse --show-toplevel)/scripts/audit-images.sh" staged
